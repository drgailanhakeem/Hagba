# ─── Hagba environment variables ─────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Settings → API). `.env.local` is gitignored.

# Public — safe to expose to the browser. Inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix this with NEXT_PUBLIC. The service-role key bypasses
# Row Level Security; if it were exposed under a NEXT_PUBLIC name it would be
# inlined into client-side JavaScript and compromise the entire database.
# Used by the account-deletion route handler.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — override the email confirmation redirect URL in local development.
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
